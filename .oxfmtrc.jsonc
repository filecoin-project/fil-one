{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "ignorePatterns": [
    ".sst",
    "contracts/lib",
    "packages/ui",
    "**/dist",
    "**/sst-env.d.ts",
    "pnpm-lock.yaml",
    "tests/s3compat/**/logs/*.json",
    "tests/s3compat/*/manifest.json",
  ],
}
