# S3-compatible provider credentials (copy to <provider>/.env and fill in)
S3_ACCESS_KEY_ID=your_access_key_here
S3_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=your-bucket-name

# Provider endpoint
S3_ENDPOINT=https://your-provider-endpoint.example.com

# Optional: user metadata used by s3-tests to verify identity responses.
# If omitted, placeholder values are derived from the provider name
# (some identity-checking tests will fail).
S3_DISPLAY_NAME=Your Name
S3_USER_ID=your-user-id
S3_EMAIL=you@example.com

# Optional: second set of credentials for cross-user compatibility tests.
# If omitted, falls back to the main credentials (cross-user tests will fail).
S3_ALT_ACCESS_KEY_ID=your_alt_access_key_here
S3_ALT_SECRET_ACCESS_KEY=your_alt_secret_key_here
S3_ALT_DISPLAY_NAME=Alt User
S3_ALT_USER_ID=your-alt-user-id
S3_ALT_EMAIL=alt@example.com

# Aurora Portal API — only needed for provider=aurora.
# The S3 bridge plugin uses these to redirect ListBuckets/CreateBucket/DeleteBucket
# through the Aurora Dashboard API (access keys can't perform these operations).
# AURORA_PORTAL_ORIGIN=https://dashboard.dev.aur.lu
# AURORA_TENANT_ID=your-tenant-uuid-here
# AURORA_NO_VERIFY_SSL=true

# Source dataset on source.coop (used by upload and load_test scripts)
SOURCE_ENDPOINT=https://data.source.coop
SOURCE_BUCKET=harvard-lil
SOURCE_PREFIX=gov-data/
