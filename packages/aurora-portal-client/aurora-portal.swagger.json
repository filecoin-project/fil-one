    "/auth/v1/tenants/{tenantId}/tokens": {
      "get": {
        "description": "Returns a list of all tokens for a tenant",
        "operationId": "ListTokens",
        "parameters": [
          {
            "description": "Tenant ID",
            "in": "path",
            "name": "tenantId",
            "required": true,
            "type": "string"
          },
          {
            "default": 1,
            "description": "Page number",
            "in": "query",
            "name": "page",
            "type": "integer"
          },
          {
            "default": 20,
            "description": "Page size",
            "in": "query",
            "name": "pageSize",
            "type": "integer"
          }
        ],
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "List of tenant tokens",
            "schema": { "$ref": "#/definitions/models.TokenListPortalResponse" }
          },
          "500": {
            "description": "Error getting tokens",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          }
        },
        "security": [{ "ApiKeyAuth": [] }],
        "summary": "List tokens",
        "tags": ["Token"]
      },
      "post": {
        "consumes": ["application/json"],
        "description": "Creates a new token for a tenant",
        "operationId": "CreateToken",
        "parameters": [
          {
            "description": "Tenant ID",
            "in": "path",
            "name": "tenantId",
            "required": true,
            "type": "string"
          },
          {
            "description": "Token creation request",
            "in": "body",
            "name": "request",
            "required": true,
            "schema": { "$ref": "#/definitions/models.CreateTokenPortalRequest" }
          }
        ],
        "produces": ["application/json"],
        "responses": {
          "201": {
            "description": "Token created",
            "schema": { "$ref": "#/definitions/models.TokenCreatePortalResponse" }
          },
          "400": {
            "description": "Invalid request body or parameters",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          },
          "409": {
            "description": "Token with this name already exists",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          },
          "500": {
            "description": "Error while creating token",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          }
        },
        "security": [{ "ApiKeyAuth": [] }],
        "summary": "Create token",
        "tags": ["Token"]
      }
    },
