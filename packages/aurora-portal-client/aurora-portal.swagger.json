  "paths": {
    "/analytics/v1/operations/buckets/{bucketName}": {
      "get": {
        "description": "Returns S3 operation metrics for a bucket, optionally filtered by requester tenant and grouped by tags",
        "operationId": "GetBucketOperationMetrics",
        "parameters": [
          {
            "description": "Bucket name",
            "in": "path",
            "name": "bucketName",
            "required": true,
            "type": "string"
          },
          {
            "description": "Start of time range (RFC3339)",
            "in": "query",
            "name": "from",
            "required": true,
            "type": "string"
          },
          {
            "description": "End of time range (RFC3339)",
            "in": "query",
            "name": "to",
            "required": true,
            "type": "string"
          },
          {
            "description": "Resample window duration, e.g., 5m, 1h. Minutes and hours are the only supported units",
            "in": "query",
            "name": "window",
            "type": "string"
          },
          {
            "description": "Group by fields (comma-separated): trafficClass,requesterTenantId",
            "in": "query",
            "name": "groupBy",
            "type": "string"
          },
          {
            "description": "Filter metrics to a requester tenant ID",
            "in": "query",
            "name": "requesterTenantId",
            "type": "string"
          }
        ],
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Operation metrics",
            "schema": { "$ref": "#/definitions/model.OperationMetricsResponse" }
          },
          "400": {
            "description": "Bad request",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          },
          "401": {
            "description": "Unauthorized",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          },
          "403": {
            "description": "Access denied",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          },
          "500": {
            "description": "Internal server error",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          }
        },
        "security": [{ "ApiKeyAuth": [] }],
        "summary": "Get bucket operation metrics",
        "tags": ["Operations"]
      }
    },
    "/analytics/v1/operations/myorg": {
      "get": {
        "description": "Returns S3 operation metrics for the authenticated tenant in the given time range, optionally resampled by window duration and grouped by tags",
        "operationId": "GetTenantOperationMetrics",
        "parameters": [
          {
            "description": "Start of time range (RFC3339)",
            "in": "query",
            "name": "from",
            "required": true,
            "type": "string"
          },
          {
            "description": "End of time range (RFC3339)",
            "in": "query",
            "name": "to",
            "required": true,
            "type": "string"
          },
          {
            "description": "Resample window duration, e.g., 5m, 1h. Minutes and hours are the only supported units",
            "in": "query",
            "name": "window",
            "type": "string"
          },
          {
            "description": "Group by fields (comma-separated): trafficClass,requesterTenantId",
            "in": "query",
            "name": "groupBy",
            "type": "string"
          }
        ],
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Operation metrics",
            "schema": { "$ref": "#/definitions/model.OperationMetricsResponse" }
          },
          "400": {
            "description": "Bad request",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          },
          "401": {
            "description": "Unauthorized",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          },
          "500": {
            "description": "Internal server error",
            "schema": { "$ref": "#/definitions/common.ReturnMessage" }
          }
        },
        "security": [{ "ApiKeyAuth": [] }],
        "summary": "Get tenant operation metrics",
        "tags": ["Operations"]
      }
    },
