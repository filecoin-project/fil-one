{
  "name": "hyperspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "sst dev",
    "build": "pnpm --filter @hyperspace/shared build && pnpm --filter @hyperspace/backend build && pnpm --filter @hyperspace/website build",
    "deploy": "pnpm build && sst deploy",
    "deploy:staging": "pnpm build && sst deploy --stage staging",
    "deploy:production": "pnpm build && sst deploy --stage production",
    "remove": "sst remove",
    "lint": "oxlint --report-unused-disable-directives && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@pulumi/aws": "^6",
    "@pulumi/command": "^1",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.3.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "sst": "^3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@pulumi/command",
      "protobufjs"
    ]
  }
}
