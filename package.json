{
  "name": "filone",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "sst dev",
    "build": "pnpm -r run build",
    "deploy": "pnpm build && sst deploy",
    "deploy:staging": "pnpm build && sst deploy --stage staging",
    "deploy:production": "pnpm build && sst deploy --stage production",
    "deploy:infra:staging": "cd infra && sst deploy --stage staging",
    "deploy:infra:production": "cd infra && sst deploy --stage production",
    "generate:api-clients": "pnpm --filter @filone/aurora-backoffice-client --filter @filone/aurora-portal-client generate",
    "remove": "sst remove",
    "lint": "oxlint --report-unused-disable-directives && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "refresh": "sst refresh",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm lint && pnpm --filter @filone/shared --filter @filone/backend --filter @filone/website test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@pulumi/aws": "^7.21.0",
    "@pulumi/command": "^1.2.1",
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.5.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "sst": "^4.2.4"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@pulumi/command",
      "protobufjs"
    ],
    "overrides": {
      "@smithy/types": "4.13.1"
    }
  }
}
