{
  "name": "filone",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "sst dev",
    "build": "pnpm -r --if-present run build",
    "deploy:dev": "pnpm run build && sst deploy",
    "deploy:staging": "pnpm run build && sst deploy --stage staging",
    "deploy:production": "pnpm run build && sst deploy --stage production",
    "deploy:infra:staging": "cd infra && sst deploy --stage staging",
    "deploy:infra:production": "cd infra && sst deploy --stage production",
    "generate:api-clients": "pnpm --filter @filone/aurora-backoffice-client --filter @filone/aurora-portal-client generate",
    "remove": "sst remove",
    "lint": "oxlint --report-unused-disable-directives && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "refresh": "sst refresh",
    "prepare": "husky",
    "test": "pnpm lint && pnpm --filter @filone/shared --filter @filone/backend --filter @filone/website test",
    "test:e2e": "pnpm exec playwright test",
    "test:integration": "pnpm --filter @filone/integration test"
  },
  "dependencies": {
    "@filone/shared": "workspace:*",
    "@sentry/vite-plugin": "^5.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@pulumi/aws": "^7.23.0",
    "@pulumi/command": "^1.2.1",
    "@types/node": "^24.12.0",
    "aws-cdk-lib": "^2.245.0",
    "constructs": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "sst": "^4.5.12"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --report-unused-disable-directives",
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc}": "oxfmt --no-error-on-unmatched-pattern --check"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@pulumi/command",
      "protobufjs"
    ],
    "overrides": {
      "@smithy/types": "4.13.1"
    }
  }
}
