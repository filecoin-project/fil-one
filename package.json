{
  "name": "hyperspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "sst dev",
    "build": "pnpm --filter @hyperspace/shared build && pnpm --filter @hyperspace/backend build && pnpm --filter @hyperspace/website build",
    "deploy": "pnpm build && sst deploy",
    "deploy:staging": "pnpm build && sst deploy --stage staging",
    "deploy:production": "pnpm build && sst deploy --stage production",
    "remove": "sst remove",
    "refresh": "sst refresh",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm --filter @hyperspace/backend test"
  },
  "devDependencies": {
    "@pulumi/aws": "^7.21.0",
    "@pulumi/command": "^1.2.1",
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.5.1",
    "sst": "^4.1.10"
  },
  "packageManager": "pnpm@10",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@pulumi/command",
      "protobufjs"
    ]
  }
}