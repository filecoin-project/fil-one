#!/usr/bin/env bash
# Tail all CloudWatch logs for a Hyperspace SST stage in realtime.
#
# Usage:
#   bin/tail-logs          # tails logs for stage $USER
#   bin/tail-logs staging  # tails logs for stage "staging"

set -euo pipefail

STAGE="${1:-$USER}"
LOG_GROUP="/hyperspace/${STAGE}"

exec aws logs tail "$LOG_GROUP" --follow --format short
